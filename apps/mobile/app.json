      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "59d2a8c8-fe8f-4e59-874f-a5887f584a20"
      }
    },
    "owner": "tianma-if-edgeever"
  }
}
