# EdgeEver 本地环境变量模板。
# 使用方式：复制为 .env.local，然后填入你自己的 Cloudflare 账号和资源信息。
# 注意：.env.local 会被 git 忽略，不要把真实 Token 或私有资源 ID 提交到公开仓库。

# Cloudflare 账号 ID。
# 可通过 `bunx wrangler whoami` 查看。
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API Token。
# 本地已经通过 `wrangler login` 登录时可以留空；CI/CD 自动部署时再填写。
CLOUDFLARE_API_TOKEN=

# Worker 服务名称。
# 默认会部署为名叫 edgeever 的 Cloudflare Worker。
EDGE_EVER_WORKER_NAME=edgeever

# D1 数据库名称。
# 创建命令：`bunx wrangler d1 create edgeever`
EDGE_EVER_D1_DATABASE_NAME=edgeever

# D1 数据库 ID。
# 创建 D1 后，把 wrangler 返回的 database_id 填到这里，并同步替换 wrangler.toml 里的占位值。
EDGE_EVER_D1_DATABASE_ID=00000000-0000-0000-0000-000000000000

# R2 生产资源桶名称。
# 创建命令：`bunx wrangler r2 bucket create edgeever-resources`
EDGE_EVER_R2_BUCKET_NAME=edgeever-resources

# R2 预览/本地开发资源桶名称。
# 可选；用于 Wrangler preview/dev 场景隔离测试附件。
EDGE_EVER_R2_PREVIEW_BUCKET_NAME=edgeever-resources-preview

# 前端访问 API 的基础地址。
# 本地开发默认指向 Wrangler dev：`bun run dev:api`
VITE_API_BASE_URL=http://127.0.0.1:8787
