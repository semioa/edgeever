# EdgeEver Worker runtime secrets template.
#
# Cloudflare Deploy Button 会读取 `.env.example` / `.dev.vars.example`，并把其中
# 每一个变量当作需要用户在部署向导里填写的 Worker Secret。
#
# 登录账号。未配置密码 hash 且 D1 中没有用户时，EdgeEver 会保持无登录保护，
# 避免一键部署后因为缺少密码变量而锁死实例。
EDGE_EVER_AUTH_USERNAME=admin

# 登录密码的 PBKDF2-SHA256 hash。
# 生成命令：`bun run auth:hash -- <你的密码>`
EDGE_EVER_AUTH_PASSWORD_HASH=

# Web session 有效期，单位：天。服务端会限制在 1-400 天。
EDGE_EVER_SESSION_TTL_DAYS=400

# 本地 CLI / Wrangler 部署所需的 Cloudflare 账号、资源和 Token 模板请看 `.env.local.example`。
